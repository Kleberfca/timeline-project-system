# .env.example
# Copie este arquivo para .env e preencha com suas credenciais

# Supabase Configuration
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anonima-aqui

# Application Settings
VITE_APP_NAME="Timeline Project System"
VITE_APP_URL=http://localhost:5173

# Storage Settings (Supabase Storage)
# Buckets são criados automaticamente via migração SQL
# - 'arquivos': Para documentos do projeto (privado)
# - 'sistema': Para logo e favicon (público)

# Environment
NODE_ENV=development
